<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>Elclark - Links</title>

    <link rel="icon" type="image/png" sizes="16x16" href="https://elclark.my.id/src/img/favicon/favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="https://elclark.my.id/src/img/favicon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="96x96" href="https://elclark.my.id/src/img/favicon/favicon-googletv.png">

    <link rel="apple-touch-icon-precomposed" sizes="120x120"
        href="https://elclark.my.id/src/img/favicon/apple-touch-icon-120x120-precomposed.png" type="image/png">
    <link rel="apple-touch-icon" sizes="180x180" href="https://elclark.my.id/src/img/favicon/apple-touch-icon.png"
        type="image/png">
    <link rel="apple-touch-icon-precomposed" sizes="152x152"
        href="https://elclark.my.id/src/img/favicon/apple-touch-icon-152x152-precomposed.png" type="image/png">

    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
    <style>
        body {
            height: 100vh;
        }

        .center-container {
            height: calc(100% - 64px);
            width: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        /* label focus color */
        .input-field input[type=text]:focus+label {
            color: rgb(202, 0, 0);
        }

        /* label underline focus color */
        .input-field input[type=text]:focus {
            border-bottom: 1px solid rgb(202, 0, 0);
            box-shadow: 0 1px 0 0 rgb(202, 0, 0);
        }
    </style>
</head>

<body class="grey darken-4 white-text">
    <nav>
        <div class="nav-wrapper grey darken-4">
            <a href="/links" class="brand-logo center"><img src="/src/img/elclark_red/250x75.png"
                    height="60px" alt="Elclark Logo"></a>
            <ul id="nav-mobile" class="right hide-on-med-and-down">
                <li><a href="/links/manage/">Manage</a></li>
                <li><a href="/logout/">Logout</a></li>
            </ul>
        </div>
    </nav>

    <div class="center-container">
        <div class="container">
            <div class="row">
                <form class="col s12" action="addlink" method="post">
                    <h4>Create Links</h4>
                    <div class="row">
                        <div class="input-field col s9">
                            <input class="white-text" id="url" name="url" type="url" class="validate" required>
                            <label for="url">Long URL (https://example.com/)</label>
                        </div>
                        <div class="input-field col s3">
                            <input class="white-text" id="short" name="short" type="text" class="validate">
                            <label for="short">Pretty Link</label>
                        </div>
                    </div>
                    <button class="btn red darken-4 waves-effect waves-light col s12" style="height: 100%;"
                        type="submit">Submit</button>
                </form>
            </div>
        </div>
    </div>
    <div class="notif" id="notif"></div>
    <script src="/src/js/notif.js"></script>
</body>

</html>